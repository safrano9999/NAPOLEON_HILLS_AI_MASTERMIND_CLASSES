# FastAPI bind address for direct run and published ports
FASTAPI_HOST=127.0.0.1

# Napoleon web UI internal port
NAPOLEON_PORT=11004

# Napoleon web UI host port
NAPOLEON_PUBLISH_PORT=11004

# Napoleon default LiteLLM proxy model
NAPOLEON_LITELLM_MODEL=deepseek-v4-flash

# BLANK = ephemeral; mount-bind Volumes for Napoleon personas and sessions (example: ./members_ai:/opt/safrano9999/NAPOLEON_HILLS_AI_MASTERMIND_CLASSES/members_ai:Z,./members:/opt/safrano9999/NAPOLEON_HILLS_AI_MASTERMIND_CLASSES/members:Z,./sessions:/opt/safrano9999/NAPOLEON_HILLS_AI_MASTERMIND_CLASSES/sessions:Z)
NAPOLEON_VOLUMES=
