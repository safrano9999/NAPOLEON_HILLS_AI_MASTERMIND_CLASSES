# Injected process environment wins over config.conf and .env
INJECT_OVERWRITE=true

# Host bind address for direct run and published ports
HOST=127.0.0.1

# Napoleon web UI internal port
NAPOLEON_PORT=7700

# Napoleon web UI host port
NAPOLEON_PUBLISH_PORT=7700

# Napoleon default LiteLLM proxy model
NAPOLEON_LITELLM_MODEL=deepseek-v4-flash
